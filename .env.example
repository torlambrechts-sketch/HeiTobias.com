# Supabase project — see Project Settings in the Supabase dashboard.
SUPABASE_PROJECT_REF=lyckwnzxwfspsbqbjddv

# Public (safe to expose to the browser).
SUPABASE_URL=https://lyckwnzxwfspsbqbjddv.supabase.co
SUPABASE_ANON_KEY=

# Service role — server-side and test-fixture setup only. NEVER ship to the browser.
# Required by scripts/setup-demo-passwords.mjs.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection for the SQL test runner and migration tools.
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Get it from: Supabase dashboard -> Project Settings -> Database -> Connection string.
SUPABASE_DB_URL=

# Browser-facing copies (Vite only exposes vars prefixed VITE_).
# Mirror SUPABASE_URL here, and use the modern publishable key
# (sb_publishable_...) from the Supabase dashboard so the smoke UI can read it.
# The client also accepts a legacy VITE_SUPABASE_ANON_KEY as a fallback.
VITE_SUPABASE_URL=https://lyckwnzxwfspsbqbjddv.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
