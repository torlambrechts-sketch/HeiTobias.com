# ─────────────────────────────────────────────────────────────────────
# HeiTobias — production environment configuration
#
# Copy this file to `.env.local` (dev / local) or set these in your
# hosting platform's secret manager (production / staging).
#
# NEVER commit a populated `.env.local`. The .gitignore covers it,
# but double-check before pushing.
#
# All values here are PLACEHOLDERS. Real values come from:
#   * Supabase dashboard → Project Settings → API
#   * SMTP provider (Postmark / SendGrid EU / SES eu-central-1)
#   * Your DNS registrar (for FROM_EMAIL, REPLY_TO_EMAIL domain)
#   * Sentry / error-tracking provider
# ─────────────────────────────────────────────────────────────────────

# ─── Environment ────────────────────────────────────────────────────
# development | staging | production
# Used by the env() helper everywhere to decide demo gating, log
# verbosity, error-tracking sample rate.
NODE_ENV=development

# Hard-deny for any demo seeding in production. Set to true ONLY in
# staging / local for the npm run seed:demo command. Production deploys
# explicitly set this to false in the secret manager.
SEED_DEMO_DATA=false

# ─── Supabase ───────────────────────────────────────────────────────
# Production MUST be EU-region (Frankfurt / Stockholm) for GDPR/AI-Act
# residency posture. The dev project is us-east-1 and labelled DEV ONLY.
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://YOUR-REF.supabase.co
SUPABASE_ANON_KEY=
# Server-side ONLY. NEVER ship to the browser. Used by seed scripts
# and the SQL test runner.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection for the SQL test runner and any worker
# that needs raw access (backup logical-dump, retention enforcer).
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Browser-exposed copies (Vite only inlines vars prefixed VITE_).
# Mirror SUPABASE_URL + SUPABASE_ANON_KEY here.
VITE_SUPABASE_URL=https://YOUR-REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Application ────────────────────────────────────────────────────
# Canonical public URL of the deployment. Used for magic-link
# generation, email link bases, ALLOWED_ORIGINS default.
APP_URL=https://app.heitobias.com
VITE_APP_URL=https://app.heitobias.com

# Comma-separated list of allowed CORS origins. NEVER use '*' in
# production. Include preview-deploy URL patterns explicitly.
ALLOWED_ORIGINS=https://app.heitobias.com

# Random 64+ char strings. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
CSRF_SECRET=

# ─── Email / SMTP ───────────────────────────────────────────────────
# postmark | sendgrid_eu | ses_eu_central_1 | console_only
# console_only is the dev default — emails write to the notifications
# outbox + log to stdout instead of sending.
SMTP_PROVIDER=console_only

# Provider-specific:
#   postmark        → server token from Postmark dashboard
#   sendgrid_eu     → API key from SendGrid (EU subprocessor selected)
#   ses_eu_central_1→ AWS access key + secret (use SES IAM-only key)
SMTP_API_KEY=
SMTP_API_SECRET=

# Sender identity. Must match a verified SPF/DKIM/DMARC domain in DNS.
FROM_EMAIL=no-reply@heitobias.com
FROM_NAME=HeiTobias
REPLY_TO_EMAIL=hello@heitobias.com

# ─── Error tracking ─────────────────────────────────────────────────
# Sentry recommended (EU data residency available). Leave empty in
# dev — the init code is a no-op without DSN.
SENTRY_DSN=
VITE_SENTRY_DSN=

# error | warn | info | debug
# Production should be info or warn; dev/staging info or debug.
LOG_LEVEL=info
VITE_LOG_LEVEL=info

# ─── Backup / retention ─────────────────────────────────────────────
# S3-compatible backup bucket for daily logical dumps. EU region only.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# Days of dumps to retain. Operator-set per the data retention policy
# decision (still HANDOFF H-6 until legal/AI-Act advisor signs off).
BACKUP_RETENTION_DAYS=30
